; Adapted from PeTTa examples/fibadd.metta for MeTTa-TS (Hyperon) conventions.

!(add-atom &self (= (fib $N)
                    (if (< $N 2)
                        $N
                        (+ (fib (- $N 1))
                           (fib (- $N 2))))))

!(test (fib 30) 832040)
