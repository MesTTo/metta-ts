; Adapted from PeTTa examples/tabling_fib.metta for MeTTa-TS (Hyperon) conventions.

!(import! &self (library lib_tabling))

!(tabled (fib $N))
(= (fib $N)
   (if (< $N 2)
       $N
       (+ (fib (- $N 1))
          (fib (- $N 2)))))

!(test (fib 30) 832040)
