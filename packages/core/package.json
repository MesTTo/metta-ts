{
  "name": "@metta-ts/core",
  "version": "1.0.5",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "neverthrow": "^8.1.0"
  },
  "author": "MesTTo",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "MeTTa (OpenCog Hyperon) interpreter in pure TypeScript: atoms, spaces, type system, pattern matching, evaluation, and the standard library.",
  "keywords": [
    "metta",
    "hyperon",
    "opencog",
    "atomspace",
    "symbolic-ai",
    "interpreter",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/Meta-TypeScript-Talk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/MesTTo/Meta-TypeScript-Talk#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/Meta-TypeScript-Talk/issues"
  }
}
