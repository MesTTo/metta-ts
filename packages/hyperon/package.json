{
  "name": "@metta-ts/hyperon",
  "version": "1.0.4",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "docs": "typedoc"
  },
  "dependencies": {
    "@metta-ts/core": "workspace:*"
  },
  "author": "MesTTo",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "description": "A TypeScript class API over @metta-ts/core, modeled on Python hyperon (atoms, spaces, grounded operations).",
  "keywords": [
    "metta",
    "hyperon",
    "opencog",
    "atomspace",
    "symbolic-ai",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/Meta-TypeScript-Talk.git",
    "directory": "packages/hyperon"
  },
  "homepage": "https://github.com/MesTTo/Meta-TypeScript-Talk#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/Meta-TypeScript-Talk/issues"
  }
}
